general_settings:
    database_url: ENC[AES256_GCM,data:Uw/hzWLKc/h/Kxrhs+4vaHzlBPOYjSfbzaBy271nsFwwtx9OwlQurXW+ToRjS3fH8sXrxPwH7TvkHhzjuRKp8v5s7V+eZk3yMVRqZyOdQLoWnQ==,iv:k0oYb0xtkfgtPGlFO9swsNYQ3YcBNyJNBeERGN/OPRQ=,tag:xbUIF38EycN6BRIC5gV5CA==,type:str]
    disable_spend_logs: false
    disable_spend_updates: false
    # économie disque, on n'a pas besoin du contenu
    store_prompts_in_spend_logs: false
router_settings:
    # route vers la clé la moins utilisée
    routing_strategy: usage-based-routing-v2
    fallbacks:
        - gpt-4o-mini:
            - groq-standard
            - mistral-small
        - groq-snapshot:
            - mistral-small
        - groq-standard:
            - ollama-cloud
            - mistral-small
        - groq-qwen:
            - mistral-small
    # 1 échec (429) → cooldown cette clé
    allowed_fails: 1
    # clé en pause 60s après rate limit
    cooldown_time: 60
    # 3 tentatives sur d'autres clés avant abandon
    num_retries: 3
    # secondes avant retry
    retry_after: 5
model_list:
