    # ══════════════════════════════════════════════════════════════
    #  OLLAMA CLOUD — Error taxonomy analysis (free tier)
    #  gpt-oss:20b-cloud via ollama.com OpenAI-compatible API
    #  No RPM/TPM limits documented — usage-based
    # ══════════════════════════════════════════════════════════════
    - model_name: ollama-cloud
      litellm_params:
        model: openai/nemotron-3-nano:30b-cloud
        api_key: ENC[AES256_GCM,data:HRuWkvH30hDHyav0896SYhAzTVODgL6PH34Z6Ap1fdVY3K91OMPnN6Tj0CloCY+/uIm0nsFtC6WO,iv:d/2V+EEWWBDakfiwsDzZaWzm3BDkGHbVfVXB0bf+4pE=,tag:xBjj/sfvyDWYQa2J0J+K3A==,type:str]
        api_base: https://ollama.com/v1
      model_info:
        owner: sinse
        tier: free
    # ══════════════════════════════════════════════════════════════
    #  GEMINI 2.5 FLASH — Judge model (Oracle V1, Session 44 κ study)
    #  Session 44 κ calibration : κ=0.84 vs Claude (almost perfect),
    #  vs gpt-4o-mini-as-judge κ=0.17 (slight only). Migrating
    #  Oracle judge to Gemini Flash for far higher inter-rater
    #  reliability. Free tier : 10 RPM, 250 RPD, 250K TPM. EEA users
    #  get paid-tier privacy automatically (no training on prompts).
    # ══════════════════════════════════════════════════════════════
    - model_name: gemini-flash
      litellm_params:
        model: gemini/gemini-2.5-flash
        api_key: ENC[AES256_GCM,data:vw4jnvUAFThDXoR0im4ffx8ntzRyZfrZHQ==,iv:YKkzYfaSLTn1fCWQy7jkWR+eXssnPvg8NoxSDMiqy2s=,tag:f1+LOv8rV2FlgZJZkTirOw==,type:str]
        # Google free tier is adaptive — officially 10 RPM / 250 RPD
        # but Google throttles down to 5 RPM / 20 RPD when usage ramps
        # or per-project policies kick in. Observed 2026-04-22 :
        # RPM=5, RPD=20 on this account. Run `preflight_gemini.py`
        # before any Oracle full-mode invocation.
        rpm: 5
      model_info:
        owner: sinse
        tier: free
    # ══════════════════════════════════════════════════════════════
    #  MISTRAL — Pool partagé (fallback si Groq saturé)
    #  Même model_name = LiteLLM load-balance automatiquement
    #  Limites free tier par clé : 2 RPM (!), 500K TPM, 1B tokens/mois
    # ══════════════════════════════════════════════════════════════
    - model_name: mistral-small
      litellm_params:
        model: mistral/mistral-small-latest
        api_key: ENC[AES256_GCM,data:KZuxBt01ANdQ7f3hnzIQXWkSKRTFK9Lr13c2cIi+CIU=,iv:zAeBEu/+71iI5Asl5LdsctBthYRshD43/2UJjq3uETY=,tag:WobcCMfzUd43jWZw8PDXGg==,type:str]
        # limite réelle Mistral free
        rpm: 2
      model_info:
        owner: sinse
        tier: free
