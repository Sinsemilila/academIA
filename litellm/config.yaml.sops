general_settings:
    database_url: ENC[AES256_GCM,data:rh6x0b0NjCW5WcH+KCC+AXiEm4DQLXRvQeuQiFWr3lZgFMEASQ1XrOLqa5gCH+pE1vDQBcEeoz/iROcqGg/55CQI/FmapAbRjBdHLNUnR4FEAA==,iv:lxmX1f9FB2OzIaRi4KLxezJSnViaPURXIKs6UVNeUM4=,tag:zIttYrjWBOe6ZzmNMqPu3Q==,type:str]
    disable_spend_logs: false
    disable_spend_updates: false
    # économie disque, on n'a pas besoin du contenu
    store_prompts_in_spend_logs: false
router_settings:
    # route vers la clé la moins utilisée
    routing_strategy: usage-based-routing-v2
    fallbacks:
        - gpt-4o-mini:
            - groq-standard
            - mistral-small
        - groq-snapshot:
            - mistral-small
        - groq-standard:
            - ollama-cloud
            - mistral-small
        - groq-qwen:
            - mistral-small
        # Session 44 — Gemini judge chain (540 RPD cumulated).
        # When gemini-flash (20 RPD) hits 429, cascade to gemini-3-flash
        # (20 RPD more), then gemini-3-1-flash-lite (500 RPD).
        # All three scored κ=0.84 vs majority in calibration.
        - gemini-flash:
            - gemini-3-flash
            - gemini-3-1-flash-lite
        - gemini-3-flash:
            - gemini-3-1-flash-lite
    # 1 échec (429) → cooldown cette clé
    allowed_fails: 1
    # clé en pause 60s après rate limit
    cooldown_time: 60
    # 3 tentatives sur d'autres clés avant abandon
    num_retries: 3
    # secondes avant retry
    retry_after: 5
model_list:
