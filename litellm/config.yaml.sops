    # ══════════════════════════════════════════════════════════════
    #  OLLAMA CLOUD — Error taxonomy analysis (free tier)
    #  gpt-oss:20b-cloud via ollama.com OpenAI-compatible API
    #  No RPM/TPM limits documented — usage-based
    # ══════════════════════════════════════════════════════════════
    - model_name: ollama-cloud
      litellm_params:
        model: openai/nemotron-3-nano:30b-cloud
        api_key: ENC[AES256_GCM,data:RIHl0mk0oWMnWh4MyZkS3mGB7Prfg/5sj8ey2DZl38QHpM7kC7+GjSTGePTE8nSd5P0dKbzWiJ3i,iv:eLSg6fVIN4KwYXXNudy4PGiv5scauF+8B0ttfXvcK64=,tag:gzsBbdQ8zrmZuY2JQ7J8Yg==,type:str]
        api_base: https://ollama.com/v1
      model_info:
        owner: sinse
        tier: free
    # ══════════════════════════════════════════════════════════════
    #  GEMINI 2.5 FLASH — Judge model (Oracle V1, Session 44 κ study)
    #  Session 44 κ calibration : κ=0.84 vs Claude (almost perfect),
    #  vs gpt-4o-mini-as-judge κ=0.17 (slight only). Migrating
    #  Oracle judge to Gemini Flash for far higher inter-rater
    #  reliability. Free tier : 10 RPM, 250 RPD, 250K TPM. EEA users
    #  get paid-tier privacy automatically (no training on prompts).
    # ══════════════════════════════════════════════════════════════
    - model_name: gemini-flash
      litellm_params:
        model: gemini/gemini-2.5-flash
        api_key: ENC[AES256_GCM,data:NAXrZQD38i0pe6fffdMV+l46NkqDLzhfUQ==,iv:DEqoDJCAu4PbNJLzltylLYXbRuV4DOzExFtBuyfF4xk=,tag:pvwK72N9nKHVUmyTKpDSAQ==,type:str]
        # Gemini free-tier per-model limits (observed 2026-04-22) :
        #   2.5 Flash      :  5 RPM,  20 RPD
        #   3 Flash preview:  5 RPM,  20 RPD
        #   3.1 Flash Lite : 15 RPM, 500 RPD
        # Limits are PER-MODEL (separate buckets), so we stack :
        # gemini-flash → gemini-3-flash → gemini-3-1-flash-lite.
        # κ calibration shows all 3 at κ=0.84 vs majority — no quality
        # loss across the cascade.
        rpm: 5
      model_info:
        owner: sinse
        tier: free
    - model_name: gemini-3-flash
      litellm_params:
        model: gemini/gemini-3-flash-preview
        api_key: ENC[AES256_GCM,data:Vg/IkuLleknd7n+hmRYw9jt2tXFrfGrd0Q==,iv:BA4HgmrUjOsqMbKZI4W9VCkfzxovms0x5eK66KJTHqM=,tag:n/mbq544qhlp07vQjNKvIg==,type:str]
        rpm: 5
      model_info:
        owner: sinse
        tier: free
    - model_name: gemini-3-1-flash-lite
      litellm_params:
        model: gemini/gemini-3.1-flash-lite-preview
        api_key: ENC[AES256_GCM,data:FJ1jviofNAFZRdYA7XDo+9QjDRPSfRUmtQ==,iv:tTw4K9y7ZasmHQaQPh8NzAQQ5gvDe8I1s18hnOMXWMs=,tag:fFNGp/96V8+44dDiuJftLg==,type:str]
        rpm: 15
      model_info:
        owner: sinse
        tier: free
    # ══════════════════════════════════════════════════════════════
    #  MISTRAL — Pool partagé (fallback si Groq saturé)
    #  Même model_name = LiteLLM load-balance automatiquement
    #  Limites free tier par clé : 2 RPM (!), 500K TPM, 1B tokens/mois
    # ══════════════════════════════════════════════════════════════
    - model_name: mistral-small
      litellm_params:
        model: mistral/mistral-small-latest
        api_key: ENC[AES256_GCM,data:FGuGQH0Zo7aYUUNFP65Z3CkjZQa/6N2vY0Y=,iv:OH/CV0gSdOx3l75E4IKQ9nWWIQnIDk4TRc/ItQmmRyw=,tag:DvnoSWoy9Zpy+fgLkJhJvw==,type:str]
        # Free tier réel observé via x-ratelimit headers (2026-04-30) :
        # 400 RPM · 1.5M tok/min · 1B tok/mois. Conservé 100 RPM pour
        # marge multi-usages (judge oracle + fallback Groq + dev).
        rpm: 100
      model_info:
        owner: sinse
        tier: free
    # ══════════════════════════════════════════════════════════════
    #  MISTRAL MEDIUM — Judge backup deeper (Session 53+ scaling Tier 1)
    #  mistral-medium-latest = 70B class, free tier accessible.
    #  Path : panel cross-provider avec cerebras-judge-fast + gemini-flash.
    # ══════════════════════════════════════════════════════════════
    - model_name: mistral-medium
      litellm_params:
        model: mistral/mistral-medium-latest
        api_key: ENC[AES256_GCM,data:8gU3w4cTwI+GXjaEAaZT5kxURdCNVcqB9NA=,iv:m9dQwETk/8/hHCcuJB4SeODqksZonrFUT+gMM5oQUuE=,tag:k8dA7ISHtZGXyPzkAaMBQw==,type:str]
        rpm: 60
      model_info:
        owner: sinse
        tier: free
    # ══════════════════════════════════════════════════════════════
    #  CEREBRAS — Free tier judge (Session 53+ scaling Tier 1)
    #  Free tier observé via x-ratelimit headers (2026-04-30) :
    #    Llama-3.1-8B : 30 RPM · 900 RPH · 14400 RPD · 1M tok/day
    #                   latency ~5ms (queue 0ms) — quasi-instant
    #    Qwen-3-235B  : RPM moins généreux mais qualité ++
    #  Path : "cerebras-judge-fast" pour battery routine (RPD high),
    #         "cerebras-judge-deep" pour calibration ponctuelle.
    # ══════════════════════════════════════════════════════════════
    - model_name: cerebras-judge-fast
      litellm_params:
        model: cerebras/llama3.1-8b
        api_key: ENC[AES256_GCM,data:lQAw9WeM/fZLKJv84wNwsYIr/MQfKv9sy6jX,iv:6e9Qqxvv0oARV7xQQCmkHwOZj4tC8j/u4MypjF8TvXM=,tag:UYTpQgcQKzrdNz0YCyJLTg==,type:str]
        rpm: 30
      model_info:
        owner: sinse
        tier: free
    - model_name: cerebras-judge-deep
      litellm_params:
        model: cerebras/qwen-3-235b-a22b-instruct-2507
        api_key: ENC[AES256_GCM,data:AQvwNCKNVH2VDWd66jEjC88OJXcsJlVivkPc,iv:mECN3D+LL3RumtyfCuHpdQK4id+gYgSjh/n0xlJr1wU=,tag:pn0hQm7X9urzEuo2pC17uw==,type:str]
        rpm: 5
      model_info:
        owner: sinse
        tier: free
