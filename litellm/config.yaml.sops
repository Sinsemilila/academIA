# ══════════════════════════════════════════════════════════════
#  ACTIVATION : Quand tu as les clés d'un pote, décommente
#  son bloc et remplace le placeholder par la vraie clé.
#  Puis : docker restart litellm-proxy
#
#  Capacité actuelle  : 1 clé  → ~6 sessions/jour
#  Capacité 5 clés    : 5 clés → ~30 sessions/jour
#
#  Le bounce est automatique (usage-based-routing-v2) :
#  Clé la moins utilisée en premier → cooldown 60s si 429
#  → clé suivante → fallback Mistral si tous les Groq down
# ══════════════════════════════════════════════════════════════
# Session 39 Block 1.2 — cached_tokens telemetry sidecar
litellm_settings:
    callbacks:
        - cache_ext.cache_stats_callback.proxy_handler_instance
