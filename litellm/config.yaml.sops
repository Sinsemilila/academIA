      model_info:
        owner: sinse
        tier: free
    # ══════════════════════════════════════════════════════════════
    #  GEMINI 2.5 FLASH — Judge model (Oracle V1, Session 44 κ study)
    #  Session 44 κ calibration : κ=0.84 vs Claude (almost perfect),
    #  vs gpt-4o-mini-as-judge κ=0.17 (slight only). Migrating
    #  Oracle judge to Gemini Flash for far higher inter-rater
    #  reliability. Free tier : 10 RPM, 250 RPD, 250K TPM. EEA users
    #  get paid-tier privacy automatically (no training on prompts).
    # ══════════════════════════════════════════════════════════════
    - model_name: gemini-flash
      litellm_params:
        model: gemini/gemini-2.5-flash
        api_key: ENC[AES256_GCM,data:L4YpR9vlHBBgdgBRhoqG8EWNhFsZL/2ORA==,iv:Mo7Zyn2eqPFJrC6mkDKRJIjfkMAoAikUOERorMMiq0U=,tag:x0Ad9m140g23dx9G+gyNAg==,type:str]
        rpm: 10
      model_info:
        owner: sinse
        tier: free
    # ══════════════════════════════════════════════════════════════
    #  MISTRAL — Pool partagé (fallback si Groq saturé)
    #  Même model_name = LiteLLM load-balance automatiquement
    #  Limites free tier par clé : 2 RPM (!), 500K TPM, 1B tokens/mois
    # ══════════════════════════════════════════════════════════════
